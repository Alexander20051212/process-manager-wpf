<Window x:Class="ProcessManagerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Manager"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== CONTROL PANEL ===== -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="Search:"
                       VerticalAlignment="Center"/>

            <TextBox Width="200"
                     Margin="5,0,20,0"
                     Text="{Binding SearchText,
                            UpdateSourceTrigger=PropertyChanged}"/>

            <ComboBox x:Name="PriorityCombo"
                      Width="150"
                      ItemsSource="{Binding PriorityLevels}"
                      Margin="0,0,10,0"/>

            <Button Content="Set Priority"
                    Command="{Binding ChangePriorityCommand}"
                    CommandParameter="{Binding SelectedItem,
                    ElementName=PriorityCombo}"/>

            <Button Content="Refresh"
                    Margin="20,0,0,0"
                    Command="{Binding RefreshCommand}"/>

            <Button Content="Kill Process"
                    Margin="10,0,0,0"
                    Background="IndianRed"
                    Command="{Binding KillProcessCommand}"/>

        </StackPanel>

        <!-- ===== PROCESS LIST ===== -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Processes}"
                  SelectedItem="{Binding SelectedProcess}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="PID"
                                    Binding="{Binding Id}"
                                    Width="80"/>

                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="220"/>

                <DataGridTextColumn Header="Priority"
                                    Binding="{Binding Priority}"
                                    Width="120"/>

                <DataGridTextColumn Header="Memory"
                                    Binding="{Binding MemoryUsage}"
                                    Width="120"/>

                <DataGridTextColumn Header="Threads"
                                    Binding="{Binding ThreadCount}"
                                    Width="80"/>

                <DataGridTextColumn Header="CPU Time"
                                    Binding="{Binding CpuTime}"
                                    Width="150"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- ===== AFFINITY + THREADS ===== -->
        <GroupBox Grid.Row="2"
                  Header="CPU Affinity &amp; Threads"
                  Margin="0,10,0,10">

            <StackPanel Margin="10">

                <ItemsControl ItemsSource="{Binding Cores}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding CoreIndex,
                                    StringFormat=Core {0}}"
                                      IsChecked="{Binding IsSelected}"
                                      Margin="5"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Apply Affinity"
                        Width="160"
                        Margin="0,10,0,10"
                        Command="{Binding ApplyAffinityCommand}"/>

                <DataGrid ItemsSource="{Binding Threads}"
                          AutoGenerateColumns="False"
                          Height="150"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thread ID"
                                            Binding="{Binding Id}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Priority"
                                            Binding="{Binding Priority}"
                                            Width="120"/>
                        <DataGridTextColumn Header="State"
                                            Binding="{Binding State}"
                                            Width="120"/>
                        <DataGridTextColumn Header="CPU Time"
                                            Binding="{Binding ProcessorTime}"
                                            Width="150"/>
                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

        </GroupBox>

        <!-- ===== PROCESS TREE ===== -->
        <GroupBox Grid.Row="3"
                  Header="Process Tree">

            <TreeView ItemsSource="{Binding ProcessTree}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate
                        ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

        </GroupBox>

    </Grid>
</Window>