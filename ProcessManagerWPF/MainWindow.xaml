<Window x:Class="ProcessManagerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Process Manager" Height="800" Width="1200">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Search:" VerticalAlignment="Center"/>
            <TextBox Width="200"
                     Margin="5"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Refresh"
                    Width="100"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <!-- Процессы -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Processes}"
                  SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

        <!-- Потоки -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Threads}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>

        <!-- Нижняя панель -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU Affinity -->
            <GroupBox Header="CPU Affinity">
                <ItemsControl ItemsSource="{Binding Cores}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding CoreIndex}"
                                      IsChecked="{Binding IsSelected}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <!-- Приоритет -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Priority:"/>
                <ComboBox ItemsSource="{Binding PriorityLevels}"
                          SelectedItem="{Binding SelectedProcess.Priority, Mode=TwoWay}"/>
                <Button Content="Apply Priority"
                        Margin="0,5,0,0"
                        Command="{Binding ChangePriorityCommand}"
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource PreviousData}}"/>
                <Button Content="Terminate"
                        Margin="0,5,0,0"
                        Command="{Binding KillCommand}"/>
                <Button Content="Apply Affinity"
                        Margin="0,5,0,0"
                        Command="{Binding ApplyAffinityCommand}"/>
            </StackPanel>

            <!-- Мониторинг -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="System Monitor"/>
                <TextBlock Text="{Binding CurrentCpu, StringFormat=CPU: {0:F1}%}"/>
                <TextBlock Text="{Binding CurrentRam, StringFormat=RAM Used: {0:F0} MB}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>