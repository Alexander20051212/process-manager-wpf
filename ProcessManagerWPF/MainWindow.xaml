<Window x:Class="ProcessManagerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Process Manager"
        Height="900"
        Width="1400"
        Background="#1E1E1E"
        Foreground="White"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer>
        <StackPanel Margin="15">

            <TextBlock Text="SYSTEM MONITOR"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding CurrentCpu, StringFormat=CPU: {0:F1}%}"/>
            <TextBlock Text="{Binding CurrentRam, StringFormat=RAM Used: {0:F0} MB}"
                       Margin="0,0,0,15"/>

            <TextBlock Text="PROCESSES"
                       FontSize="20"
                       FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBox Width="250"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Margin="5,0"/>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Processes}"
                      SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                      AutoGenerateColumns="True"
                      Height="250"
                      IsReadOnly="True"/>

            <TextBlock Text="Change Priority" Margin="0,10,0,0"/>

            <ComboBox ItemsSource="{Binding PriorityLevels}"
                      SelectedItem="{Binding SelectedProcess.Priority}"
                      Width="200"/>

            <Button Content="Apply Priority"
                    Command="{Binding ChangePriorityCommand}"
                    CommandParameter="{Binding SelectedProcess.Priority}"
                    Margin="0,5"/>

            <Button Content="Terminate Process"
                    Command="{Binding KillCommand}"
                    Margin="0,5"/>

            <TextBlock Text="THREADS"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,15,0,5"/>

            <DataGrid ItemsSource="{Binding Threads}"
                      AutoGenerateColumns="True"
                      Height="200"
                      IsReadOnly="True"/>

            <TextBlock Text="CPU Affinity"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,15,0,5"/>

            <ItemsControl ItemsSource="{Binding Cores}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding CoreIndex}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Apply Affinity"
                    Command="{Binding ApplyAffinityCommand}"
                    Margin="0,5"/>

            <TextBlock Text="PROCESS TREE"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,15,0,5"/>

            <TreeView ItemsSource="{Binding ProcessTree}"
                      Height="250">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

        </StackPanel>
    </ScrollViewer>
</Window>